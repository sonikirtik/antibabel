{
  "manifest_version": 3,
  "name": "Gemma Grammarly Local",
  "version": "1.0",
  "description": "Uses a local Gemma 4 E2B model to improve text inside any text input area.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8086/"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}